{
  "manifest_version": 3,
  "name": "JumpNav: The most elegant AI chat navigator you’ve ever seen.",
  "description": "Floating navigator for ChatGPT,Gemini,Claude. Turn long chats into clickable prompt outlines with reply previews and one-click jump.",
  "version": "3.1.1",
  "icons": {
    "16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "action": {
    "default_title": "JumpNav",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "logo16.png",
      "24": "logo24.png",
      "32": "logo32.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content/vendor/mathjax-config.js",
        "content/vendor/mathjax4.js",
        "content/vendor/katex.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
