{
  "manifest_version": 3,
  "name": "__MSG_manifest_extension_name__",
  "description": "__MSG_manifest_extension_description__",
  "version": "3.4.0",
  "default_locale": "en",
  "icons": {
    "16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "action": {
    "default_title": "__MSG_manifest_action_title__",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "logo16.png",
      "24": "logo24.png",
      "32": "logo32.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content/vendor/mathjax-config.js",
        "content/vendor/mathjax4.js",
        "content/vendor/katex.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
